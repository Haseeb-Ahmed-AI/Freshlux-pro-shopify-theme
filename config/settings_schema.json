[
  {
    "name": "theme_info",
    "theme_name": "FreshLux",
    "theme_version": "1.0.0",
    "theme_author": "Custom",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "header",
        "content": "Primary Colors"
      },
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary Color",
        "default": "#1a3c34",
        "info": "Used for buttons, links, and accents"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "Secondary Color",
        "default": "#c9a962",
        "info": "Used for highlights and luxury accents"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent Color",
        "default": "#87a878",
        "info": "Used for freshness indicators and badges"
      },
      {
        "type": "header",
        "content": "Background & Text"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Background Color",
        "default": "#faf9f7"
      },
      {
        "type": "color",
        "id": "color_foreground",
        "label": "Text Color",
        "default": "#2d2d2d"
      },
      {
        "type": "header",
        "content": "Status Colors"
      },
      {
        "type": "color",
        "id": "color_error",
        "label": "Error Color",
        "default": "#c45c5c"
      },
      {
        "type": "color",
        "id": "color_success",
        "label": "Success Color",
        "default": "#3d9970"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Headings"
      },
      {
        "type": "font_picker",
        "id": "type_header_font",
        "default": "playfair_display_n4",
        "label": "Heading Font",
        "info": "Elegant serif font for premium feel"
      },
      {
        "type": "header",
        "content": "Body Text"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "default": "inter_n4",
        "label": "Body Font",
        "info": "Clean sans-serif for readability"
      },
      {
        "type": "range",
        "id": "type_body_font_size",
        "min": 12,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "Base Font Size",
        "default": 16
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 1000,
        "max": 1600,
        "step": 50,
        "unit": "px",
        "label": "Page Width",
        "default": 1400
      },
      {
        "type": "range",
        "id": "spacing_sections",
        "min": 20,
        "max": 100,
        "step": 5,
        "unit": "px",
        "label": "Space Between Sections",
        "default": 50
      }
    ]
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 50,
        "max": 300,
        "step": 10,
        "unit": "px",
        "label": "Logo Width",
        "default": 150
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "options": [
          {
            "value": "drawer",
            "label": "Drawer"
          },
          {
            "value": "page",
            "label": "Page"
          }
        ],
        "default": "drawer",
        "label": "Cart Type"
      },
      {
        "type": "checkbox",
        "id": "show_cart_note",
        "default": true,
        "label": "Show Cart Note"
      },
      {
        "type": "checkbox",
        "id": "enable_delivery_scheduler",
        "default": true,
        "label": "Enable Delivery Scheduler",
        "info": "Allow customers to select delivery date and time"
      }
    ]
  },
  {
    "name": "Products",
    "settings": [
      {
        "type": "header",
        "content": "Product Cards"
      },
      {
        "type": "checkbox",
        "id": "show_secondary_image",
        "default": true,
        "label": "Show Second Image on Hover"
      },
      {
        "type": "checkbox",
        "id": "show_vendor",
        "default": true,
        "label": "Show Vendor"
      },
      {
        "type": "checkbox",
        "id": "show_quick_add",
        "default": true,
        "label": "Enable Quick Add to Cart"
      },
      {
        "type": "header",
        "content": "Badges"
      },
      {
        "type": "checkbox",
        "id": "show_sale_badge",
        "default": true,
        "label": "Show Sale Badge"
      },
      {
        "type": "checkbox",
        "id": "show_sold_out_badge",
        "default": true,
        "label": "Show Sold Out Badge"
      }
    ]
  },
  {
    "name": "Collection Pages",
    "settings": [
      {
        "type": "select",
        "id": "default_layout",
        "options": [
          {
            "value": "grid",
            "label": "Grid"
          },
          {
            "value": "list",
            "label": "List"
          }
        ],
        "default": "grid",
        "label": "Default Layout"
      },
      {
        "type": "range",
        "id": "products_per_page",
        "min": 8,
        "max": 48,
        "step": 4,
        "label": "Products Per Page",
        "default": 24
      },
      {
        "type": "checkbox",
        "id": "enable_filtering",
        "default": true,
        "label": "Enable Product Filtering"
      },
      {
        "type": "checkbox",
        "id": "enable_sorting",
        "default": true,
        "label": "Enable Product Sorting"
      },
      {
        "type": "select",
        "id": "filter_type",
        "options": [
          {
            "value": "sidebar",
            "label": "Sidebar"
          },
          {
            "value": "drawer",
            "label": "Drawer"
          },
          {
            "value": "horizontal",
            "label": "Horizontal"
          }
        ],
        "default": "sidebar",
        "label": "Filter Layout"
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "header",
        "content": "Social Links"
      },
      {
        "type": "text",
        "id": "social_facebook_link",
        "label": "Facebook",
        "info": "https://facebook.com/yourstore"
      },
      {
        "type": "text",
        "id": "social_instagram_link",
        "label": "Instagram",
        "info": "https://instagram.com/yourstore"
      },
      {
        "type": "text",
        "id": "social_twitter_link",
        "label": "Twitter",
        "info": "https://twitter.com/yourstore"
      },
      {
        "type": "text",
        "id": "social_youtube_link",
        "label": "YouTube",
        "info": "https://youtube.com/yourstore"
      },
      {
        "type": "text",
        "id": "social_pinterest_link",
        "label": "Pinterest",
        "info": "https://pinterest.com/yourstore"
      },
      {
        "type": "text",
        "id": "social_tiktok_link",
        "label": "TikTok",
        "info": "https://tiktok.com/@yourstore"
      }
    ]
  },
  {
    "name": "Search",
    "settings": [
      {
        "type": "checkbox",
        "id": "predictive_search_enabled",
        "default": true,
        "label": "Enable Predictive Search"
      },
      {
        "type": "checkbox",
        "id": "predictive_search_show_vendor",
        "default": true,
        "label": "Show Vendor in Results"
      },
      {
        "type": "checkbox",
        "id": "predictive_search_show_price",
        "default": true,
        "label": "Show Price in Results"
      }
    ]
  }
]
