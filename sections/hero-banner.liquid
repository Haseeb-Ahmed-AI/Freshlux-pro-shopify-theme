<section class="hero-banner">
  <div class="hero-banner__media">
    {% if section.settings.video != blank %}
      {{ section.settings.video | video_tag:
        autoplay: true,
        muted: true,
        loop: true,
        playsinline: true,
        class: 'hero-banner__video'
      }}
    {% endif %}
    <div class="hero-banner__overlay"></div>
  </div>

  <div class="hero-banner__content page-width">
    <div class="hero-banner__inner">
      <div class="hero-banner__top">
        <p class="hero-banner__subheading">
          {{ section.settings.subheading }}
        </p>
        <h1 class="hero-banner__heading">
          {{ section.settings.heading }}
        </h1>
      </div>

      <div class="hero-banner__bottom">
        <a href="{{ section.settings.button_link }}" class="button button--primary">
          {{ section.settings.button_label }}
        </a>
        <a href="{{ section.settings.button_link_2 }}" class="button button--secondary">
          {{ section.settings.button_label_2 }}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
/* ===== HERO BASE ===== */
.hero-banner {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9; /* 🔑 allows full video visibility */
  overflow: hidden;
  background: #000;
}

/* ===== MEDIA ===== */
.hero-banner__media {
  position: absolute;
  inset: 0;
}

.hero-banner__video {
  width: 100%;
  height: 100%;
  object-fit: cover; /* desktop default */
}

/* ===== OVERLAY ===== */
.hero-banner__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.35);
}

/* ===== CONTENT ===== */
.hero-banner__content {
  position: absolute;
  inset: 0;
  z-index: 2;
}

.hero-banner__inner {
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 3rem 0;
  color: #fff;
}

.hero-banner__top {
  max-width: 520px;
}

.hero-banner__subheading {
  font-size: 1.8rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #f5c56b;
  margin-bottom: 1rem;
}

.hero-banner__heading {
  font-size: clamp(3rem, 5vw, 5.5rem);
  line-height: 1.1;
}

/* ===== BUTTONS ===== */
.hero-banner__bottom {
  display: flex;
  gap: 1.2rem;
}

/* ===== RESPONSIVE BEHAVIOR ===== */
@media (max-width: 1024px) {
  .hero-banner {
    aspect-ratio: 4 / 3;
  }
}

@media (max-width: 768px) {
  .hero-banner {
    aspect-ratio: 16 / 9;
  }

  .hero-banner__video {
    object-fit: contain; /* 🔑 FULL VIDEO ON MOBILE */
  }

  .hero-banner__bottom {
    flex-direction: column;
  }

  .hero-banner__bottom .button {
    width: 100%;
  }
}
/* =========================
   MOBILE HERO POLISH
========================= */
@media (max-width: 768px) {
  .hero-banner__inner {
    padding: 2.5rem 1.5rem;
    text-align: center;
  }

  .hero-banner__top {
    max-width: 100%;
    margin-top: 2.5rem; /* push content below header */
  }

  .hero-banner__subheading {
    font-size: 1.4rem;
    letter-spacing: 0.12em;
    margin-bottom: 0.8rem;
  }

  .hero-banner__heading {
    font-size: clamp(2.4rem, 6vw, 3.2rem);
    line-height: 1.2;
  }

  .hero-banner__bottom {
    margin-top: 2.5rem;
    gap: 1rem;
  }

  .hero-banner__bottom .button {
    width: 100%;
    padding: 1.2rem 1.5rem;
    font-size: 1.4rem;
    min-height: 48px; /* touch-friendly but not bulky */
  }
}
/* =========================
   MOBILE ONLY – NO DESKTOP CHANGES
========================= */
@media (max-width: 749px) {
  .hero-banner__inner {
    text-align: left;
    padding: 2rem 1.5rem;
  }

  .hero-banner__top {
    margin-top: 1.2rem;
    max-width: 100%;
  }

  .hero-banner__subheading {
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
  }

  .hero-banner__heading {
    font-size: clamp(2.4rem, 6vw, 3.2rem);
    line-height: 1.15;
  }

  .hero-banner__bottom {
    margin-top: 2rem;
    gap: 0.75rem;
  }

  .hero-banner__bottom .button {
    padding: 0.85rem 1.2rem;
    font-size: 1.25rem;
    min-height: 42px;
  }
  /* ===============================
   MOBILE HARD OVERRIDES (NO DESKTOP)
================================ */
@media (max-width: 749px) {

  /* Force content to top-left */
  .hero-banner__content {
    display: block;
  }

  .hero-banner__inner {
    justify-content: flex-start !important;
    align-items: flex-start !important;
    padding-top: 1.5rem !important;
    padding-left: 1.5rem !important;
    padding-right: 1.5rem !important;
    text-align: left !important;
  }

  .hero-banner__top {
    margin-top: 0 !important;
    max-width: 100% !important;
  }

  .hero-banner__subheading {
    font-size: 1.25rem !important;
    margin-bottom: 0.4rem !important;
  }

  .hero-banner__heading {
    font-size: 2.6rem !important;
    line-height: 1.15 !important;
  }

  /* Shrink buttons properly */
  .hero-banner__bottom {
    margin-top: 1.6rem !important;
    gap: 0.6rem !important;
    width: 100%;
  }

  .hero-banner__bottom .button {
    padding: 0.75rem 1rem !important;
    font-size: 1.15rem !important;
    min-height: 38px !important;
    height: auto !important;
    width: 100%;
  }
}
/* =========================
   MOBILE FIX – NO DESKTOP CHANGE
========================= */
@media (max-width: 749px) {

  /* Remove Shopify page-width centering */
  .hero-banner__content.page-width {
    max-width: 100%;
    padding-left: 0;
    padding-right: 0;
  }

  /* Pin content to top-left */
  .hero-banner__inner {
    justify-content: flex-start !important;
    align-items: flex-start !important;
    padding: 1.25rem 1.25rem !important;
    text-align: left !important;
  }

  .hero-banner__top {
    margin-top: 0 !important;
    max-width: 100% !important;
  }

  .hero-banner__subheading {
    font-size: 1.2rem !important;
    margin-bottom: 0.3rem !important;
  }

  .hero-banner__heading {
    font-size: 2.4rem !important;
    line-height: 1.15 !important;
  }

  /* Smaller buttons on mobile */
  .hero-banner__bottom {
    margin-top: 1.4rem !important;
    gap: 0.6rem !important;
    width: 100%;
  }

  .hero-banner__bottom .button {
    padding: 0.65rem 1rem !important;
    font-size: 1.1rem !important;
    min-height: 36px !important;
    width: 100%;
  }
}
/* =========================
   MOBILE BUTTON HARD FIX
   (NO DESKTOP IMPACT)
========================= */
@media (max-width: 749px) {

  .hero-banner__bottom {
    width: 100%;
    margin-top: 1.2rem !important;
    gap: 0.5rem !important;
  }

  .hero-banner__bottom .button {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;

    /* 🔥 actual size control */
    min-height: unset !important;
    height: 38px !important;
    padding: 0 1.2rem !important;

    font-size: 1.05rem !important;
    line-height: 1 !important;

    width: 100% !important;
    max-width: 100% !important;
  }
}
/* =================================================
   FINAL MOBILE FIX — BUTTON SIZE + POSITION
   (NO DESKTOP IMPACT)
================================================= */
@media (max-width: 749px) {

  /* Layout control */
  .hero-banner__inner {
    justify-content: space-between !important;
    align-items: flex-start !important;
    padding: 1.25rem !important;
    text-align: left !important;
  }

  /* Keep text at top-left */
  .hero-banner__top {
    margin-top: 0 !important;
    max-width: 100% !important;
  }

  .hero-banner__subheading {
    font-size: 1.2rem !important;
    margin-bottom: 0.3rem !important;
  }

  .hero-banner__heading {
    font-size: 2.4rem !important;
    line-height: 1.15 !important;
  }

  /* Buttons pinned bottom-left */
  .hero-banner__bottom {
    margin-top: auto !important;
    width: auto !important;
    gap: 0.5rem !important;
    align-items: flex-start !important;
  }

  /* ACTUAL button size fix */
  .hero-banner__bottom .button {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;

    height: 34px !important;
    min-height: 0 !important;
    padding: 0 1rem !important;

    font-size: 1rem !important;
    line-height: 1 !important;

    width: auto !important;
    max-width: none !important;
  }
}

}

</style>

{% schema %}
{
  "name": "Adaptive Video Hero",
  "settings": [
    { "type": "video", "id": "video", "label": "Background Video" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Premium Quality" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Grocery Delivery" },
    { "type": "text", "id": "button_label", "label": "Primary Button", "default": "Shop Now" },
    { "type": "url", "id": "button_link", "label": "Primary Link" },
    { "type": "text", "id": "button_label_2", "label": "Secondary Button", "default": "Learn More" },
    { "type": "url", "id": "button_link_2", "label": "Secondary Link" }
  ],
  "presets": [
    { "name": "Adaptive Video Hero" }
  ]
}
{% endschema %}
