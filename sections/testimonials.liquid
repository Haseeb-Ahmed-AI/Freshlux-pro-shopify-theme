{%- comment -%}
  Testimonials Section
  Customer reviews and testimonials display
{%- endcomment -%}

<section class="testimonials section" style="background-color: {{ section.settings.background_color }};">
  <div class="page-width">
    <div class="section__header">
      {%- if section.settings.subheading != blank -%}
        <p class="section__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      <h2 class="section__title">{{ section.settings.heading }}</h2>
    </div>

    <div class="testimonials__grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-{{ section.settings.columns }}" style="gap: var(--spacing-lg);">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'testimonial' -%}
            <div class="testimonial-card" {{ block.shopify_attributes }}>
              <div class="testimonial-card__rating">
                {%- for i in (1..5) -%}
                  {%- if i <= block.settings.rating -%}
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="var(--color-secondary)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                  {%- else -%}
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                  {%- endif -%}
                {%- endfor -%}
              </div>
              <blockquote class="testimonial-card__quote">
                "{{ block.settings.quote }}"
              </blockquote>
              <div class="testimonial-card__author">
                {%- if block.settings.author_image != blank -%}
                  <img
                    src="{{ block.settings.author_image | image_url: width: 100 }}"
                    alt="{{ block.settings.author_name | escape }}"
                    width="50"
                    height="50"
                    loading="lazy"
                    class="testimonial-card__author-image"
                  >
                {%- else -%}
                  <div class="testimonial-card__author-placeholder">
                    {{ block.settings.author_name | slice: 0 | upcase }}
                  </div>
                {%- endif -%}
                <div class="testimonial-card__author-info">
                  <p class="testimonial-card__author-name">{{ block.settings.author_name }}</p>
                  {%- if block.settings.author_location != blank -%}
                    <p class="testimonial-card__author-location">{{ block.settings.author_location }}</p>
                  {%- endif -%}
                </div>
              </div>
            </div>
        {%- endcase -%}
      {%- endfor -%}

      {%- if section.blocks.size == 0 -%}
        {%- for i in (1..3) -%}
          <div class="testimonial-card">
            <div class="testimonial-card__rating">
              {%- for j in (1..5) -%}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-secondary)" stroke="var(--color-secondary)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
              {%- endfor -%}
            </div>
            <blockquote class="testimonial-card__quote">
              "The quality of their produce is incredible. Everything arrives fresh and perfectly packed. Best grocery delivery service I've used!"
            </blockquote>
            <div class="testimonial-card__author">
              <div class="testimonial-card__author-placeholder">S</div>
              <div class="testimonial-card__author-info">
                <p class="testimonial-card__author-name">Sarah M.</p>
                <p class="testimonial-card__author-location">New York, NY</p>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .testimonials {
    background-color: rgba(var(--color-primary-rgb), 0.03);
  }

  .section__subheading {
    margin: 0 0 var(--spacing-sm);
    font-size: 1.3rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-secondary);
  }

  .testimonials__grid {
    margin-top: var(--spacing-xl);
  }

  .testimonial-card {
    background-color: #fff;
    padding: var(--spacing-xl);
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .testimonial-card__rating {
    display: flex;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-md);
  }

  .testimonial-card__quote {
    margin: 0 0 var(--spacing-lg);
    font-size: 1.6rem;
    font-style: italic;
    line-height: 1.7;
    color: var(--color-foreground);
  }

  .testimonial-card__author {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
  }

  .testimonial-card__author-image {
    width: 50px;
    height: 50px;
    border-radius: var(--border-radius-full);
    object-fit: cover;
  }

  .testimonial-card__author-placeholder {
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-primary);
    color: #fff;
    border-radius: var(--border-radius-full);
    font-size: 1.8rem;
    font-weight: 600;
  }

  .testimonial-card__author-name {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-foreground);
  }

  .testimonial-card__author-location {
    margin: var(--spacing-xs) 0 0;
    font-size: 1.3rem;
    color: rgba(var(--color-foreground-rgb), 0.6);
  }
</style>

{% schema %}
{
  "name": "Testimonials",
  "class": "section-testimonials",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Customer Reviews"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns (Desktop)",
      "default": 3
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "transparent"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Rating",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "The quality of their produce is incredible. Everything arrives fresh and perfectly packed. Best grocery delivery service I've used!"
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Author Image"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author Name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "author_location",
          "label": "Author Location",
          "default": "New York, NY"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial", "settings": { "author_name": "John D.", "author_location": "Los Angeles, CA", "quote": "Fast delivery, great selection, and competitive prices. I've been a loyal customer for over a year now!" } },
        { "type": "testimonial", "settings": { "author_name": "Emily R.", "author_location": "Chicago, IL", "quote": "Their organic selection is unmatched. Love supporting a business that cares about quality and sustainability." } }
      ]
    }
  ]
}
{% endschema %}
