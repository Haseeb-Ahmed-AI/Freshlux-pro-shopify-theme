{%- comment -%}
  Main Search Section
  Search results page
{%- endcomment -%}

<section class="search-page section">
  <div class="page-width">
    <div class="search-page__header">
      <h1 class="search-page__title">{{ 'general.search.title' | t }}</h1>
      <form action="{{ routes.search_url }}" method="get" role="search" class="search-page__form">
        <div class="search-page__input-wrapper">
          {%- render 'icon-search' -%}
          <input
            type="search"
            name="q"
            class="search-page__input"
            placeholder="{{ 'general.search.placeholder' | t }}"
            value="{{ search.terms | escape }}"
          >
          <button type="submit" class="button button--primary">{{ 'general.search.search' | t }}</button>
        </div>
        <input type="hidden" name="type" value="product">
      </form>
    </div>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <p class="search-page__count">{{ 'general.search.results_count' | t: count: search.results_count, terms: search.terms }}</p>

        {%- paginate search.results by 24 -%}
          <div class="search-page__results grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4" style="gap: var(--spacing-lg);">
            {%- for item in search.results -%}
              {%- if item.object_type == 'product' -%}
                <div class="search-page__item">
                  {%- render 'product-card', product: item -%}
                </div>
              {%- elsif item.object_type == 'article' -%}
                <div class="search-page__item search-page__item--article">
                  <article class="article-card">
                    {%- if item.image -%}
                      <a href="{{ item.url }}" class="article-card__image">
                        <img src="{{ item.image | image_url: width: 400 }}" alt="{{ item.title | escape }}" loading="lazy">
                      </a>
                    {%- endif -%}
                    <div class="article-card__content">
                      <p class="article-card__type">Article</p>
                      <h3><a href="{{ item.url }}">{{ item.title }}</a></h3>
                      <p>{{ item.content | strip_html | truncate: 100 }}</p>
                    </div>
                  </article>
                </div>
              {%- elsif item.object_type == 'page' -%}
                <div class="search-page__item search-page__item--page">
                  <div class="page-card">
                    <p class="page-card__type">Page</p>
                    <h3><a href="{{ item.url }}">{{ item.title }}</a></h3>
                    <p>{{ item.content | strip_html | truncate: 100 }}</p>
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            <nav class="pagination" aria-label="Pagination">
              <ul class="pagination__list">
                {%- if paginate.previous -%}
                  <li><a href="{{ paginate.previous.url }}" class="pagination__link">Previous</a></li>
                {%- endif -%}
                {%- for part in paginate.parts -%}
                  <li>
                    {%- if part.is_link -%}
                      <a href="{{ part.url }}" class="pagination__link">{{ part.title }}</a>
                    {%- else -%}
                      <span class="pagination__link pagination__link--current">{{ part.title }}</span>
                    {%- endif -%}
                  </li>
                {%- endfor -%}
                {%- if paginate.next -%}
                  <li><a href="{{ paginate.next.url }}" class="pagination__link">Next</a></li>
                {%- endif -%}
              </ul>
            </nav>
          {%- endif -%}
        {%- endpaginate -%}
      {%- else -%}
        <div class="search-page__empty">
          <p>{{ 'general.search.no_results' | t: terms: search.terms }}</p>
          <p>{{ 'general.search.no_results_suggestions' | t }}</p>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

<style>
  .search-page__header {
    text-align: center;
    margin-bottom: var(--spacing-2xl);
  }

  .search-page__title {
    margin-bottom: var(--spacing-lg);
  }

  .search-page__form {
    max-width: 600px;
    margin: 0 auto;
  }

  .search-page__input-wrapper {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    padding: var(--spacing-sm) var(--spacing-md);
    border: 1px solid rgba(var(--color-foreground-rgb), 0.2);
    border-radius: var(--border-radius-md);
  }

  .search-page__input {
    flex-grow: 1;
    border: none;
    font-size: 1.6rem;
    background: transparent;
    outline: none;
  }

  .search-page__count {
    margin-bottom: var(--spacing-lg);
    color: rgba(var(--color-foreground-rgb), 0.6);
  }

  .search-page__empty {
    text-align: center;
    padding: var(--spacing-2xl) 0;
  }

  .search-page__empty p {
    margin: 0 0 var(--spacing-md);
    color: rgba(var(--color-foreground-rgb), 0.6);
  }

  .page-card {
    padding: var(--spacing-lg);
    background-color: #fff;
    border-radius: var(--border-radius-md);
    box-shadow: var(--shadow-sm);
  }

  .page-card__type,
  .article-card__type {
    margin: 0 0 var(--spacing-xs);
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-secondary);
  }

  .pagination {
    margin-top: var(--spacing-2xl);
  }
</style>

{% schema %}
{
  "name": "Search Results",
  "class": "section-search"
}
{% endschema %}
