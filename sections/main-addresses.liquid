{%- comment -%}
  Main Addresses Section
  Customer addresses management
{%- endcomment -%}

<section class="addresses-page section">
  <div class="page-width">
    <h1>{{ 'customer.addresses.title' | t }}</h1>

    <button type="button" class="button button--primary" onclick="document.getElementById('AddAddressForm').classList.toggle('hidden')">
      {{ 'customer.addresses.add_new' | t }}
    </button>

    <div id="AddAddressForm" class="address-form hidden">
      <h2>{{ 'customer.addresses.add_new' | t }}</h2>
      {%- form 'customer_address', customer.new_address -%}
        <div class="form-row">
          <div class="form-group">
            <label for="AddressFirstName" class="form-label">{{ 'customer.addresses.first_name' | t }}</label>
            <input type="text" id="AddressFirstName" name="address[first_name]" class="form-input" autocomplete="given-name">
          </div>
          <div class="form-group">
            <label for="AddressLastName" class="form-label">{{ 'customer.addresses.last_name' | t }}</label>
            <input type="text" id="AddressLastName" name="address[last_name]" class="form-input" autocomplete="family-name">
          </div>
        </div>

        <div class="form-group">
          <label for="AddressCompany" class="form-label">{{ 'customer.addresses.company' | t }}</label>
          <input type="text" id="AddressCompany" name="address[company]" class="form-input" autocomplete="organization">
        </div>

        <div class="form-group">
          <label for="AddressAddress1" class="form-label">{{ 'customer.addresses.address1' | t }}</label>
          <input type="text" id="AddressAddress1" name="address[address1]" class="form-input" autocomplete="address-line1">
        </div>

        <div class="form-group">
          <label for="AddressAddress2" class="form-label">{{ 'customer.addresses.address2' | t }}</label>
          <input type="text" id="AddressAddress2" name="address[address2]" class="form-input" autocomplete="address-line2">
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="AddressCity" class="form-label">{{ 'customer.addresses.city' | t }}</label>
            <input type="text" id="AddressCity" name="address[city]" class="form-input" autocomplete="address-level2">
          </div>
          <div class="form-group">
            <label for="AddressCountry" class="form-label">{{ 'customer.addresses.country' | t }}</label>
            <select id="AddressCountry" name="address[country]" class="form-select" autocomplete="country">
              {{ all_country_option_tags }}
            </select>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="AddressProvince" class="form-label">{{ 'customer.addresses.province' | t }}</label>
            <select id="AddressProvince" name="address[province]" class="form-select" autocomplete="address-level1"></select>
          </div>
          <div class="form-group">
            <label for="AddressZip" class="form-label">{{ 'customer.addresses.zip' | t }}</label>
            <input type="text" id="AddressZip" name="address[zip]" class="form-input" autocomplete="postal-code">
          </div>
        </div>

        <div class="form-group">
          <label for="AddressPhone" class="form-label">{{ 'customer.addresses.phone' | t }}</label>
          <input type="tel" id="AddressPhone" name="address[phone]" class="form-input" autocomplete="tel">
        </div>

        <div class="form-group">
          <label class="form-checkbox">
            <input type="checkbox" name="address[default]" value="1">
            <span>{{ 'customer.addresses.set_default' | t }}</span>
          </label>
        </div>

        <button type="submit" class="button button--primary">{{ 'customer.addresses.add' | t }}</button>
        <button type="button" class="button button--ghost" onclick="document.getElementById('AddAddressForm').classList.add('hidden')">{{ 'customer.addresses.cancel' | t }}</button>
      {%- endform -%}
    </div>

    <div class="addresses-list">
      {%- for address in customer.addresses -%}
        <div class="address-card">
          {%- if address == customer.default_address -%}
            <span class="badge badge--new">{{ 'customer.addresses.default' | t }}</span>
          {%- endif -%}
          {{ address | format_address }}
          <div class="address-card__actions">
            <button type="button" class="button button--ghost button--small">{{ 'customer.addresses.edit' | t }}</button>
            <button type="button" class="button button--ghost button--small" onclick="if(confirm('{{ 'customer.addresses.delete_confirm' | t }}')){Shopify.postLink('{{ address.url }}', {'parameters': {'_method': 'delete'}})}">{{ 'customer.addresses.delete' | t }}</button>
          </div>
        </div>
      {%- endfor -%}
    </div>

    <a href="{{ routes.account_url }}" class="addresses-page__back">
      {%- render 'icon-arrow-right' -%}
      {{ 'customer.account.return' | t }}
    </a>
  </div>
</section>

<style>
  .addresses-page h1 {
    margin-bottom: var(--spacing-lg);
  }

  .address-form {
    margin: var(--spacing-xl) 0;
    padding: var(--spacing-xl);
    background-color: rgba(var(--color-foreground-rgb), 0.03);
    border-radius: var(--border-radius-md);
  }

  .address-form.hidden {
    display: none;
  }

  .address-form h2 {
    margin-bottom: var(--spacing-lg);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-md);
  }

  .addresses-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--spacing-lg);
    margin: var(--spacing-xl) 0;
  }

  .address-card {
    padding: var(--spacing-lg);
    background-color: #fff;
    border-radius: var(--border-radius-md);
    box-shadow: var(--shadow-sm);
  }

  .address-card .badge {
    margin-bottom: var(--spacing-sm);
  }

  .address-card__actions {
    margin-top: var(--spacing-md);
    display: flex;
    gap: var(--spacing-sm);
  }

  .addresses-page__back {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    color: var(--color-foreground);
  }

  .addresses-page__back svg {
    transform: rotate(180deg);
  }

  @media screen and (max-width: 749px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Addresses",
  "class": "section-addresses"
}
{% endschema %}
