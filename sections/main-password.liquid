{%- comment -%}
  Main Password Section
  Password page content
{%- endcomment -%}

<h2 class="password-page__title">{{ 'general.password_page.opening_soon' | t | default: 'Opening Soon' }}</h2>

{%- if shop.password_message != blank -%}
  <p class="password-page__message">{{ shop.password_message }}</p>
{%- endif -%}

{%- form 'storefront_password', class: 'password-form' -%}
  {%- if form.errors -%}
    <p class="password-form__error">{{ form.errors | default_errors }}</p>
  {%- endif -%}

  <input
    type="password"
    name="password"
    class="password-form__input"
    placeholder="{{ 'general.password_page.password_placeholder' | t | default: 'Enter store password' }}"
    required
  >

  <button type="submit" class="password-form__submit">
    {{ 'general.password_page.enter' | t | default: 'Enter' }}
  </button>
{%- endform -%}

{% schema %}
{
  "name": "Password Page",
  "class": "section-password"
}
{% endschema %}
