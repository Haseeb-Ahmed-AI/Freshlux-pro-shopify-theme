{%- comment -%}
  Main Reset Password Section
{%- endcomment -%}

<section class="reset-password-page section">
  <div class="page-width">
    <div class="reset-password-page__wrapper">
      <h1>{{ 'customer.reset_password.title' | t }}</h1>
      <p>{{ 'customer.reset_password.subtext' | t: email: email }}</p>

      {%- form 'reset_customer_password' -%}
        <div class="form-group">
          <label for="Password" class="form-label">{{ 'customer.reset_password.password' | t }}</label>
          <input type="password" id="Password" name="customer[password]" class="form-input" autocomplete="new-password" required>
        </div>

        <div class="form-group">
          <label for="PasswordConfirm" class="form-label">{{ 'customer.reset_password.password_confirm' | t }}</label>
          <input type="password" id="PasswordConfirm" name="customer[password_confirmation]" class="form-input" autocomplete="new-password" required>
        </div>

        <button type="submit" class="button button--primary button--full">{{ 'customer.reset_password.submit' | t }}</button>
      {%- endform -%}
    </div>
  </div>
</section>

<style>
  .reset-password-page__wrapper {
    max-width: 450px;
    margin: 0 auto;
    text-align: center;
  }

  .reset-password-page__wrapper h1 {
    margin-bottom: var(--spacing-md);
  }

  .reset-password-page__wrapper p {
    margin-bottom: var(--spacing-xl);
    color: rgba(var(--color-foreground-rgb), 0.6);
  }

  .reset-password-page__wrapper .form-group {
    text-align: left;
  }
</style>

{% schema %}
{
  "name": "Reset Password",
  "class": "section-reset-password"
}
{% endschema %}
