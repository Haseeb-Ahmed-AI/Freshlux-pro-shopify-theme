{%- comment -%}
  Featured Categories Section
  Auto-packed grid with no gaps when items are added/removed
{%- endcomment -%}

<section class="featured-categories section">
  <div class="page-width">
    <div class="section__header">
      {% if section.settings.subheading != blank %}
        <p class="section__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
      <h2 class="section__title">{{ section.settings.heading }}</h2>
    </div>

    <div class="featured-categories__grid">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'category' %}
            {% assign collection = collections[block.settings.collection] %}
            <a
              href="{{ collection.url | default: block.settings.link }}"
              class="category-card category-card--{{ block.settings.size }}"
              {{ block.shopify_attributes }}
            >
              <div class="category-card__media">
                {% if block.settings.image != blank %}
                  <img
                    src="{{ block.settings.image | image_url: width: 800 }}"
                    srcset="
                      {{ block.settings.image | image_url: width: 400 }} 400w,
                      {{ block.settings.image | image_url: width: 600 }} 600w,
                      {{ block.settings.image | image_url: width: 800 }} 800w
                    "
                    sizes="(max-width: 749px) 100vw, (max-width: 989px) 50vw, 33vw"
                    alt="{{ block.settings.title | escape }}"
                    loading="lazy"
                    class="category-card__image"
                  >
                {% elsif collection.image != blank %}
                  <img
                    src="{{ collection.image | image_url: width: 800 }}"
                    alt="{{ collection.title | escape }}"
                    loading="lazy"
                    class="category-card__image"
                  >
                {% else %}
                  <div class="category-card__placeholder">
                    {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  </div>
                {% endif %}
                <div class="category-card__overlay"></div>
              </div>

              <div class="category-card__content">
                <h3 class="category-card__title">
                  {{ block.settings.title | default: collection.title | default: 'Category' }}
                </h3>

                {% if block.settings.subtitle != blank %}
                  <p class="category-card__subtitle">{{ block.settings.subtitle }}</p>
                {% elsif collection != blank %}
                  <p class="category-card__subtitle">
                    {{ collection.products_count }} Products
                  </p>
                {% endif %}

                <span class="category-card__cta">
                  Shop Now {% render 'icon-arrow-right' %}
                </span>
              </div>
            </a>
        {% endcase %}
      {% endfor %}

      {% if section.blocks.size == 0 %}
        {% for i in (1..6) %}
          <div class="category-card category-card--normal">
            <div class="category-card__media">
              <div class="category-card__placeholder">
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
              <div class="category-card__overlay"></div>
            </div>
            <div class="category-card__content">
              <h3 class="category-card__title">Category {{ i }}</h3>
              <p class="category-card__subtitle">Shop the collection</p>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

<style>
/* ===== GRID ===== */
.featured-categories__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--spacing-lg);
  grid-auto-rows: 1fr; /* 🔥 KEY FIX */
}


/* ===== CARD ===== */
.category-card {
  position: relative;
  display: block;
  border-radius: var(--border-radius-lg);
  overflow: hidden;
  color: #fff;
  text-decoration: none;
  aspect-ratio: 1;
}

/* ===== SIZE VARIANTS ===== */
.category-card {
  aspect-ratio: 1 / 1;
}

/* Desktop: horizontal emphasis only */
.category-card--wide {
  grid-column: span 2;
}

.category-card--large,
.category-card--tall {
  grid-column: span 1;
  grid-row: span 1; /* 🚫 no vertical spanning */
}


/* ===== MEDIA ===== */
.category-card__media {
  position: absolute;
  inset: 0;
}

.category-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.category-card:hover .category-card__image {
  transform: scale(1.05);
}

/* ===== OVERLAY ===== */
.category-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(0, 0, 0, 0.75) 0%,
    rgba(0, 0, 0, 0) 60%
  );
}

/* ===== CONTENT ===== */
.category-card__content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacing-lg);
  z-index: 1;
}

.category-card__title {
  margin: 0 0 var(--spacing-xs);
  font-size: 2rem;
  font-weight: 800; /* 🔥 BOLD */
  color: #d4af37;   /* 🔥 GOLD */
  text-transform: uppercase;
}
.category-card--large .category-card__title {
  font-size: 2.8rem;
}

.category-card__subtitle {
  margin: 0 0 var(--spacing-sm);
  font-size: 1.4rem;
  opacity: 0.85;
}

/* ===== CTA ===== */
.category-card__cta {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 1.3rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--color-secondary);
  opacity: 0;
  transform: translateY(10px);
  transition: 0.3s ease;
}

.category-card:hover .category-card__cta {
  opacity: 1;
  transform: translateY(0);
}

/* ===== RESPONSIVE ===== */
@media (max-width: 989px) {
  .featured-categories__grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .category-card--large,
  .category-card--tall {
    grid-row: span 1;
  }
}
@media (max-width: 749px) {
  .category-card {
    aspect-ratio: 16 / 9;
  }

  .category-card--tall {
    grid-row: span 2;
  }
}

@media (max-width: 749px) {
  .featured-categories__grid {
    grid-template-columns: 1fr;
    gap: var(--spacing-md);
  }

  .category-card {
    aspect-ratio: 16 / 9;
  }

  .category-card__cta {
    opacity: 1;
    transform: none;
  }
}
/* =========================
   MOBILE FLOW FIX ONLY
   (NO STYLE CHANGES)
========================= */
@media (max-width: 749px) {

  /* Let cards size naturally on mobile */
  .featured-categories__grid {
    grid-auto-rows: auto;
  }
/* =========================
   MOBILE – SLIGHTLY BOLDER TEXT
   (NO DESKTOP IMPACT)
========================= */
@media (max-width: 749px) {

  .category-card__title {
    font-weight: 1000; /* stronger than desktop */
  }

  .category-card__subtitle {
    font-weight: 800;
  }

  .category-card__cta {
    font-weight: 800;
  }

}


}

</style>

{% schema %}
{
  "name": "Featured Categories",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Browse by Category"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Department"
    }
    
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Custom Image" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "subtitle", "label": "Subtitle" },
        { "type": "url", "id": "link", "label": "Custom Link" },
        {
          "type": "select",
          "id": "size",
          "label": "Card Size",
          "options": [
            { "value": "normal", "label": "Normal" },
            { "value": "large", "label": "Large (2x2)" },
            { "value": "wide", "label": "Wide (2x1)" },
            { "value": "tall", "label": "Tall (1x2)" }
          ],
          "default": "normal"
        }
      ]
    }
  ],
  "presets": [
    { "name": "Featured Categories" }
  ]
}
{% endschema %}
