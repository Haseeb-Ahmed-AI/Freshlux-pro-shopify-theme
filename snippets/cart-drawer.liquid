{%- comment -%}
  Cart Drawer Snippet
  Slide-out cart with items, totals, and checkout button
{%- endcomment -%}

<div class="overlay" data-cart-overlay></div>
<div class="drawer cart-drawer" data-cart-drawer>
  <div class="drawer__header">
    <h2 class="drawer__title">{{ 'sections.cart.title' | t }} ({{ cart.item_count }})</h2>
    <button type="button" class="drawer__close" data-cart-close aria-label="{{ 'accessibility.close' | t }}">
      {%- render 'icon-close' -%}
    </button>
  </div>

  <div class="drawer__body" data-cart-drawer-content>
    {%- if cart.item_count > 0 -%}
      <div class="cart-drawer__items">
        {%- for item in cart.items -%}
          <div class="cart-drawer__item" data-cart-item="{{ item.key }}">
            <div class="cart-drawer__item-image">
              {%- if item.image -%}
                <a href="{{ item.url }}">
                  <img
                    src="{{ item.image | image_url: width: 150 }}"
                    alt="{{ item.title | escape }}"
                    width="75"
                    height="75"
                    loading="lazy"
                  >
                </a>
              {%- endif -%}
            </div>

            <div class="cart-drawer__item-details">
              <h3 class="cart-drawer__item-title">
                <a href="{{ item.url }}">{{ item.product.title }}</a>
              </h3>

              {%- unless item.product.has_only_default_variant -%}
                <p class="cart-drawer__item-variant">{{ item.variant.title }}</p>
              {%- endunless -%}

              {%- if item.selling_plan_allocation -%}
                <p class="cart-drawer__item-selling-plan">{{ item.selling_plan_allocation.selling_plan.name }}</p>
              {%- endif -%}

              <div class="cart-drawer__item-price">
                {%- if item.original_line_price != item.final_line_price -%}
                  <span class="price__sale">{{ item.final_line_price | money }}</span>
                  <span class="price__compare">{{ item.original_line_price | money }}</span>
                {%- else -%}
                  <span class="price__regular">{{ item.final_line_price | money }}</span>
                {%- endif -%}
              </div>

              <div class="cart-drawer__item-quantity">
                <div class="quantity-selector">
                  <button type="button" class="quantity-selector__button" data-quantity-minus aria-label="Decrease quantity">
                    {%- render 'icon-minus' -%}
                  </button>
                  <input
                    type="number"
                    class="quantity-selector__input"
                    data-quantity-input
                    data-cart-quantity="{{ item.key }}"
                    value="{{ item.quantity }}"
                    min="0"
                    max="{{ item.variant.inventory_quantity | default: 99 }}"
                    aria-label="Quantity"
                  >
                  <button type="button" class="quantity-selector__button" data-quantity-plus aria-label="Increase quantity">
                    {%- render 'icon-plus' -%}
                  </button>
                </div>

                <button type="button" class="cart-drawer__item-remove" data-cart-remove="{{ item.key }}" aria-label="{{ 'sections.cart.remove' | t }}">
                  {%- render 'icon-trash' -%}
                </button>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- comment -%} Cart Note {%- endcomment -%}
      {%- if settings.show_cart_note -%}
        <div class="cart-drawer__note">
          <label for="CartDrawerNote" class="form-label">{{ 'sections.cart.note' | t }}</label>
          <textarea
            id="CartDrawerNote"
            name="note"
            class="form-textarea"
            placeholder="{{ 'sections.cart.note_placeholder' | t }}"
          >{{ cart.note }}</textarea>
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="cart-drawer__empty">
        <p>{{ 'sections.cart.empty' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="button button--primary">
          {{ 'sections.cart.continue_shopping' | t }}
        </a>
      </div>
    {%- endif -%}
  </div>

  {%- if cart.item_count > 0 -%}
    <div class="drawer__footer">
      {%- comment -%} Free Shipping Progress {%- endcomment -%}
      {%- assign free_shipping_threshold = 5000 -%}
      {%- assign cart_total_cents = cart.total_price -%}
      {%- assign remaining = free_shipping_threshold | minus: cart_total_cents -%}

      {%- if remaining > 0 -%}
        <div class="cart-drawer__shipping-progress">
          <p>{{ 'sections.cart.free_shipping_remaining' | t: amount: remaining | money }}</p>
          <div class="cart-drawer__shipping-bar">
            {%- assign progress = cart_total_cents | times: 100 | divided_by: free_shipping_threshold -%}
            <div class="cart-drawer__shipping-fill" style="width: {{ progress }}%;"></div>
          </div>
        </div>
      {%- else -%}
        <div class="cart-drawer__shipping-success">
          {%- render 'icon-check' -%}
          <p>{{ 'sections.cart.free_shipping_success' | t }}</p>
        </div>
      {%- endif -%}

      <div class="cart-drawer__totals">
        <div class="cart-drawer__subtotal">
          <span>{{ 'sections.cart.subtotal' | t }}</span>
          <span data-cart-total>{{ cart.total_price | money }}</span>
        </div>
        <p class="cart-drawer__taxes-note">{{ 'sections.cart.taxes_note' | t }}</p>
      </div>

      <div class="cart-drawer__buttons">
        <a href="{{ routes.cart_url }}" class="button button--outline button--full">
          {{ 'sections.cart.view_cart' | t }}
        </a>
        <a href="{{ routes.cart_url }}/checkout" class="button button--primary button--full">
          {{ 'sections.cart.checkout' | t }}
        </a>
      </div>
    </div>
  {%- endif -%}
</div>

<style>
  .cart-drawer {
    max-width: 420px;
  }

  .cart-drawer__items {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .cart-drawer__item {
    display: flex;
    gap: var(--spacing-md);
    padding-bottom: var(--spacing-lg);
    border-bottom: 1px solid rgba(var(--color-foreground-rgb), 0.1);
  }

  .cart-drawer__item:last-child {
    border-bottom: none;
  }

  .cart-drawer__item-image {
    flex-shrink: 0;
    width: 75px;
  }

  .cart-drawer__item-image img {
    width: 100%;
    border-radius: var(--border-radius-sm);
  }

  .cart-drawer__item-details {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .cart-drawer__item-title {
    margin: 0;
    font-size: 1.4rem;
    font-weight: 500;
    line-height: 1.3;
  }

  .cart-drawer__item-title a {
    color: var(--color-foreground);
  }

  .cart-drawer__item-variant,
  .cart-drawer__item-selling-plan {
    margin: 0;
    font-size: 1.2rem;
    color: rgba(var(--color-foreground-rgb), 0.6);
  }

  .cart-drawer__item-price {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .cart-drawer__item-price .price__regular,
  .cart-drawer__item-price .price__sale {
    font-size: 1.4rem;
  }

  .cart-drawer__item-price .price__compare {
    font-size: 1.2rem;
  }

  .cart-drawer__item-quantity {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-top: auto;
  }

  .cart-drawer__item-remove {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: transparent;
    border: none;
    color: rgba(var(--color-foreground-rgb), 0.5);
    cursor: pointer;
    transition: color var(--transition-fast);
  }

  .cart-drawer__item-remove:hover {
    color: var(--color-error);
  }

  .cart-drawer__note {
    margin-top: var(--spacing-lg);
    padding-top: var(--spacing-lg);
    border-top: 1px solid rgba(var(--color-foreground-rgb), 0.1);
  }

  .cart-drawer__note textarea {
    min-height: 80px;
  }

  .cart-drawer__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--spacing-2xl) 0;
    gap: var(--spacing-lg);
  }

  .cart-drawer__empty p {
    margin: 0;
    color: rgba(var(--color-foreground-rgb), 0.6);
  }

  .cart-drawer__shipping-progress {
    margin-bottom: var(--spacing-lg);
  }

  .cart-drawer__shipping-progress p {
    margin: 0 0 var(--spacing-sm);
    font-size: 1.3rem;
    color: rgba(var(--color-foreground-rgb), 0.7);
  }

  .cart-drawer__shipping-bar {
    height: 4px;
    background-color: rgba(var(--color-foreground-rgb), 0.1);
    border-radius: var(--border-radius-full);
    overflow: hidden;
  }

  .cart-drawer__shipping-fill {
    height: 100%;
    background-color: var(--color-secondary);
    transition: width var(--transition-base);
  }

  .cart-drawer__shipping-success {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-lg);
    color: var(--color-success);
  }

  .cart-drawer__shipping-success p {
    margin: 0;
    font-size: 1.3rem;
  }

  .cart-drawer__totals {
    margin-bottom: var(--spacing-lg);
  }

  .cart-drawer__subtotal {
    display: flex;
    justify-content: space-between;
    font-size: 1.6rem;
    font-weight: 600;
  }

  .cart-drawer__taxes-note {
    margin: var(--spacing-xs) 0 0;
    font-size: 1.2rem;
    color: rgba(var(--color-foreground-rgb), 0.6);
  }

  .cart-drawer__buttons {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }
</style>
